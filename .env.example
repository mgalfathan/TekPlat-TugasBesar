# --- Database ---
# Development (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Postgres on a VM):
# DATABASE_URL="postgresql://USER:PASSWORD@VM_IP:5432/sportlytics?schema=public"

# --- API providers ---
FOOTBALL_API_PROVIDER="api-football"
API_FOOTBALL_KEY=""
FOOTBALL_DATA_API_KEY=""

# --- App defaults ---
DEFAULT_COUNTRY="England"
DEFAULT_LEAGUE_ID="39"
DEFAULT_SEASON="2024"
LIVE_POLL_INTERVAL_SECONDS="30"

# --- Auth ---
# REQUIRED in production. Generate with: openssl rand -base64 48
JWT_SECRET=""
